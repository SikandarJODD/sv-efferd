v class=\"mt-5 flex flex-col gap-2\">\r\n\t\t\t\t\t<Button class=\"w-full\" variant=\"outline\">Sign In</Button>\r\n\t\t\t\t\t<Button class=\"w-full\">Get Started</Button>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</Portal>\r\n\t{/if}\r\n</div>\r\n",
