{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "portal",
	"title": "Portal",
	"type": "registry:block",
	"dependencies": [
		"bits-ui"
	],
	"devDependencies": [
		"bits-ui@^2.16.3",
		"@internationalized/date@^3.12.0"
