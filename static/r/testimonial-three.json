{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "testimonial-three",
	"title": "Testimonial Three",
	"type": "registry:block",
	"description": "A three-card testimonial grid with decorative corners, lifted middle emphasis, and richer profile metadata.",
	"dependencies": [
		"@lucide/svelte"
	],
	"devDependencies": [
		"@lucide/svelte@^0.577.0"
	],
