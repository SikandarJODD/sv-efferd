			"content": "import type { Icon } from '@lucide/svelte';\r\nimport type { Component } from 'svelte';\r\n\r\nexport type LinkItemType = {\r\n\tlabel: string;\r\n\tdescription?: string;\r\n\ticon: typeof Icon | Component;\r\n\thref: string;\r\n};\r\n",
